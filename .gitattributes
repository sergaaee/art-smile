# Normalize text files to LF in the repository, regardless of the
# committer's OS line-ending settings.
* text=auto eol=lf

# Explicitly mark binary assets so Git never applies text/EOL
# normalization to them (which can silently corrupt the file).
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.gif binary
*.svg binary
*.woff binary
*.woff2 binary
